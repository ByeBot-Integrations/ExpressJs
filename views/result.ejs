<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Result - Ray CAPTCHA Express Demo</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 100%);
      color: #fff;
      min-height: 100vh;
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .card {
      background: #1e1e2e;
      border-radius: 12px;
      padding: 2rem;
      max-width: 400px;
      text-align: center;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .status {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 1rem;
      color: <% if (success) { %>#10b981<% } else { %>#ef4444<% } %>;
    }

    .message {
      color: #94a3b8;
      margin-bottom: 1.5rem;
    }

    a {
      display: inline-block;
      padding: 0.75rem 1.5rem;
      background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
      color: #fff;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 600;
    }

    a:hover {
      opacity: 0.9;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="status"><%= message %></div>
    <div class="message">
      <% if (success && username) { %>
        Welcome, <%= username %>!
      <% } else if (!success) { %>
        Please try again.
      <% } %>
    </div>
    <a href="/">Back to Form</a>
  </div>
</body>
</html>
